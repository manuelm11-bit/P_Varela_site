# Copiar este ficheiro para ".env" e preencher com os valores reais
# NUNCA partilhar o ficheiro .env — contém informação sensível

# URL de ligação à base de dados PostgreSQL
# Formato: postgres://utilizador:password@host:porta/nome_da_base
# Exemplo local:  postgres://postgres:minhapassword@localhost:5432/biblioteca
# Exemplo remoto: postgres://admin:abc123@192.168.1.10:5432/biblioteca_escolar
DATABASE_URL=postgres://utilizador:password@localhost:5432/nome_da_base

# Chave secreta para as sessões de login (pode ser qualquer frase longa)
# Exemplo: SESSION_SECRET=biblioteca_montijo_chave_2025_xyz
SESSION_SECRET=alterar_para_uma_frase_longa_e_secreta

# Porta onde o servidor vai correr (por omissão: 5000)
PORT=5000
